# Casa Voice V3 Dual backend URL
# Local development (default):
VITE_VOICE_SERVER_URL=ws://localhost:8080/ws/voice

# Optional: auth token if the voice server has VOICE_SERVER_API_KEY set
VITE_VOICE_SERVER_API_KEY=

# Production example (deploy the voice backend separately):
# VITE_VOICE_SERVER_URL=wss://your-casa-voice.fly.dev/ws/voice
# VITE_VOICE_SERVER_API_KEY=your-secret-token
